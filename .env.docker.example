# Copy to .env.docker before running docker compose.
# Never commit .env.docker.

# Host binding used by 1Panel/Nginx/Caddy. Keep loopback in production so
# clients cannot bypass the reverse proxy by visiting the VPS IP directly.
APP_BIND_IP=127.0.0.1
APP_PORT=9800
TZ=Asia/Shanghai
# Match the Linux owner of .env.docker/package/uploads (`id -u` / `id -g`).
# App, worker and migrator run as this non-root identity.
GANKAIGC_RUNTIME_UID=1000
GANKAIGC_RUNTIME_GID=1000

# Docker Hub mirror prefix. Set to empty if your VPS can pull Docker Hub directly.
DOCKER_IMAGE_PREFIX=docker.m.daocloud.io/
# Production overlay pins PostgreSQL 16 Alpine by digest. Override only with a
# separately verified digest; changing image family may change secret-file UID.
# POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine@sha256:<verified-digest>
# Signed release deployment (docker-compose.prod.yml) must pin a digest:
# GANKAIGC_IMAGE=ghcr.io/mumu-0922/gankaigc@sha256:<verified-digest>
# Production file secrets are created under this ignored 0700 directory.
GANKAIGC_SECRETS_DIR=./secrets

# Compatibility path for local/base Compose. The production overlay reads
# service-specific 0600 files under GANKAIGC_SECRETS_DIR instead.
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
# Optional base-Compose migrator compatibility settings:
# POSTGRES_MIGRATOR_USER=gankaigc_migrator
# POSTGRES_MIGRATOR_PASSWORD=replace-with-a-strong-migrator-password

# Production PostgreSQL role split. Keep these stable after provisioning.
POSTGRES_BOOTSTRAP_ROLE=ai_polish
POSTGRES_OWNER_ROLE=gankaigc_owner
POSTGRES_MIGRATOR_ROLE=gankaigc_migrator
POSTGRES_APP_ROLE=gankaigc_app
POSTGRES_BACKUP_ROLE=gankaigc_backup
# Existing public-schema objects are never re-owned without this explicit,
# one-time switch after a verified backup. Return it to false immediately.
POSTGRES_REASSIGN_EXISTING_OBJECTS=false

# Server deployment mode requires non-default secrets.
APP_ENV=production
SECRET_KEY=replace-with-a-random-secret-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ENCRYPTION_KEY=replace-with-fernet-key-generated-by-python

# If using a domain, set this to your final origin, for example:
# ALLOWED_ORIGINS=https://your-domain.com,http://localhost:9800
ALLOWED_ORIGINS=http://localhost:9800
# Only list the actual 1Panel/OpenResty peer IP or CIDR. Forwarded client IP
# headers from any other source are ignored.
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Platform API defaults. Users can also use BYOK in the web UI.
# Cloud/public Docker deployments must use public HTTPS Base URLs.
# Keep ALLOW_LOCAL_MODEL_PROXY=false when SERVER_HOST is 0.0.0.0.
# For local-only Docker testing, set SERVER_HOST=127.0.0.1 and
# ALLOW_LOCAL_MODEL_PROXY=true, then use http://host.docker.internal:<port>/v1.
# Do not use https://127.0.0.1:<port>/v1 for local proxy mode.
ALLOW_LOCAL_MODEL_PROXY=false
OPENAI_API_KEY=replace-with-platform-api-key-or-leave-placeholder-for-byok-only
OPENAI_BASE_URL=https://api.openai.com/v1
POLISH_MODEL=gpt-5.5
POLISH_API_KEY=replace-with-platform-api-key-or-leave-placeholder-for-byok-only
POLISH_BASE_URL=https://api.openai.com/v1
ENHANCE_MODEL=gpt-5.5
ENHANCE_API_KEY=replace-with-platform-api-key-or-leave-placeholder-for-byok-only
ENHANCE_BASE_URL=https://api.openai.com/v1
EMOTION_MODEL=gpt-5.5
EMOTION_API_KEY=replace-with-platform-api-key-or-leave-placeholder-for-byok-only
EMOTION_BASE_URL=https://api.openai.com/v1
COMPRESSION_MODEL=gpt-5.5
COMPRESSION_API_KEY=replace-with-platform-api-key-or-leave-placeholder-for-byok-only
COMPRESSION_BASE_URL=https://api.openai.com/v1

MAX_CONCURRENT_USERS=7
API_REQUEST_INTERVAL=6
ENABLE_VERBOSE_AI_LOGS=false
AUTH_RATE_LIMIT_PER_MINUTE=10
REDEEM_RATE_LIMIT_PER_MINUTE=20
STREAM_TOKEN_EXPIRE_SECONDS=120
WORD_FORMATTER_ENABLED=false
MAX_UPLOAD_FILE_SIZE_MB=20
ZHUQUE_DETECT_TIMEOUT=180
ZHUQUE_DETECT_INTERVAL=2
ZHUQUE_VISIBLE_CAPTCHA_WAIT_SECONDS=600
# 朱雀检测传输：VPS/Docker 推荐 browser_agent；本机源码/一键包可用 auto 或 local_browser。
# 可选值：auto, local_browser, browser_agent, server_headless。
ZHUQUE_DETECT_TRANSPORT=browser_agent
# VPS 推荐关闭服务器无头兜底，避免朱雀识别 headless/VPS 后触发验证码或风控。
ZHUQUE_SERVER_HEADLESS_FALLBACK=false
ZHUQUE_BROWSER_AGENT_JOB_TIMEOUT=900
ZHUQUE_BROWSER_AGENT_HEARTBEAT_TIMEOUT=120
ZHUQUE_BROWSER_AGENT_PAIRING_TTL_SECONDS=600
ZHUQUE_BROWSER_AGENT_LONG_POLL_SECONDS=25
ZHUQUE_DETECT_PERSISTENT_PROFILE=false
# 本地可见检测默认会自动探测/启动系统 Chrome/Edge/Brave，并通过 CDP 复用一个浏览器资料目录。
# VPS browser_agent 模式不需要公开 CDP，也不要求用户手动启动 --remote-debugging-port。
ZHUQUE_DETECT_AUTO_SYSTEM_BROWSER=true
# 可选：高级用户可指定已启动浏览器的 Chrome DevTools 端点。
# 示例：ZHUQUE_DETECT_CDP_ENDPOINT=http://127.0.0.1:9222
ZHUQUE_DETECT_CDP_ENDPOINT=
# 可选：指定自动启动检测浏览器的可执行文件或用户数据目录。
ZHUQUE_DETECT_BROWSER_EXECUTABLE=
ZHUQUE_DETECT_BROWSER_USER_DATA_DIR=

# PDF 结构解析：默认使用 MinerU 精准解析，失败自动回退 MarkItDown。
PDF_STRUCTURE_ENGINE=mineru
PDF_STRUCTURE_FALLBACK_ENGINE=markitdown
MINERU_BASE_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_IS_OCR=false
MINERU_LANGUAGE=ch
MINERU_TIMEOUT_SECONDS=300
MINERU_POLL_INTERVAL_SECONDS=2.0

ADMIN_DATABASE_MANAGER_ENABLED=false
ADMIN_DATABASE_WRITE_ENABLED=false
INLINE_TASK_WORKER_ENABLED=false
TASK_WORKER_POLL_INTERVAL=2
TASK_WORKER_HEARTBEAT_INTERVAL=30
TASK_WORKER_STALE_TIMEOUT_SECONDS=120
TASK_WORKER_LEASE_TIMEOUT_SECONDS=120
TASK_WORKER_MAX_ATTEMPTS=3
TASK_EVENT_POLL_INTERVAL_SECONDS=1
TASK_WORKER_STOP_GRACE_PERIOD=10m

# Docker 自动数据库备份：默认每天备份一次，保留最近 14 天，文件写入宿主机 ./backups。
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# Optional encrypted offsite backup: enable with `--profile offsite` only after
# configuring and testing a separate restic repository (S3/SFTP/etc.).
# RESTIC_REPOSITORY=s3:https://s3.example.com/gankaigc
# RESTIC_PASSWORD=replace-with-a-long-independent-backup-password
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
RESTIC_INTERVAL_SECONDS=86400
RESTIC_KEEP_DAILY=14
RESTIC_KEEP_WEEKLY=8
RESTIC_KEEP_MONTHLY=12

# VPS 更新采用手动 SSH 模式：后台只检测版本并提供复制命令。
# 登录 VPS 后在项目目录执行：
#   git fetch --tags origin main
#   git pull --ff-only origin main
#   docker compose --env-file .env.docker up -d --build
VPS_UPDATE_ENABLED=false
