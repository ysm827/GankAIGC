# GankAIGC Windows 一键整合包配置
# 首次运行 start.bat 会自动生成数据库密码、JWT 密钥、加密密钥和后台密码。

SERVER_HOST=127.0.0.1
SERVER_PORT=9800
APP_ENV=desktop
ALLOWED_ORIGINS=http://localhost:9800,http://127.0.0.1:9800
AUTO_OPEN_BROWSER=true
ENABLE_VERBOSE_AI_LOGS=false

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DB=ai_polish
POSTGRES_USER=ai_polish
POSTGRES_PASSWORD=replace-with-generated-postgres-password
DATABASE_URL=postgresql://ai_polish:replace-with-generated-postgres-password@127.0.0.1:55432/ai_polish
REDIS_URL=redis://localhost:6379/0

AUTH_RATE_LIMIT_PER_MINUTE=10
REDEEM_RATE_LIMIT_PER_MINUTE=20
REGISTRATION_ENABLED=true
WORD_FORMATTER_ENABLED=false
ADMIN_DATABASE_MANAGER_ENABLED=true
ADMIN_DATABASE_WRITE_ENABLED=false
INLINE_TASK_WORKER_ENABLED=true
TASK_WORKER_POLL_INTERVAL=2
TASK_WORKER_HEARTBEAT_INTERVAL=30
TASK_WORKER_STALE_TIMEOUT_SECONDS=1800

ZHUQUE_DETECT_TRANSPORT=auto
ZHUQUE_DETECT_HEADLESS=false
ZHUQUE_DETECT_AUTO_SYSTEM_BROWSER=true
ZHUQUE_SERVER_HEADLESS_FALLBACK=false
ZHUQUE_USER_DATA_DIR=data\zhuque\users
ZHUQUE_DETECT_BROWSER_EXECUTABLE=

OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
POLISH_MODEL=gpt-5.5
POLISH_API_KEY=your-api-key-here
POLISH_BASE_URL=https://api.openai.com/v1
ENHANCE_MODEL=gpt-5.5
ENHANCE_API_KEY=your-api-key-here
ENHANCE_BASE_URL=https://api.openai.com/v1
EMOTION_MODEL=gpt-5.5
EMOTION_API_KEY=your-api-key-here
EMOTION_BASE_URL=https://api.openai.com/v1
COMPRESSION_MODEL=gpt-5.5
COMPRESSION_API_KEY=your-api-key-here
COMPRESSION_BASE_URL=https://api.openai.com/v1

SECRET_KEY=replace-with-generated-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
USER_ACCESS_TOKEN_EXPIRE_MINUTES=10080
STREAM_TOKEN_EXPIRE_SECONDS=120
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-generated-admin-password
DEFAULT_USAGE_LIMIT=1
SEGMENT_SKIP_THRESHOLD=15
